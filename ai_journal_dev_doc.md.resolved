## 5. 数据层级模型

### 5.1 三层数据结构

渐进式披露的数据基础是三层分离的信息结构：

```mermaid
graph LR
    subgraph "Layer 1: Catalog"
        L1["title\nsource\ncategory\ntimestamp"]
    end
    subgraph "Layer 2: Abstract"
        L2["abstract\n(50-200 tokens)"]
    end
    subgraph "Layer 3: Full Content"
        L3["full body text\nimages\nlinks"]
    end

    L1 -->|"AI Stage 1 可见"| L1
    L2 -->|"Content Reveal 按需加载"| L2
    L3 -->|"仅在必要时加载"| L3

    style L1 fill:#22c55e,stroke:#16a34a,color:#fff
    style L2 fill:#f59e0b,stroke:#d97706,color:#000
    style L3 fill:#ef4444,stroke:#dc2626,color:#fff
```

### 5.2 SourceItem 数据模型

```typescript
/** 原始抓取的信息条目 */
interface SourceItem {
  id: string;                    // UUID
  title: string;                 // Layer 1
  source: string;                // Layer 1 — 来源名称 (e.g., "Nature")
  category: string;              // Layer 1 — 领域分类
  url: string;                   // 原始链接
  timestamp: string;             // ISO 8601 时间戳
  abstract: string | null;       // Layer 2 — 摘要（可能为空）
  content: string | null;        // Layer 3 — 全文（可能为空）
  imageUrl: string | null;       // 来源的主图 (og:image 或 RSS media)

  // —— Curator AI 写入的字段 ——
  curatedSummary: string | null;       // Curator 整理后的摘要

  // —— 重用管理字段 ——
  usageCount: number;                  // 被使用次数
  usageWeight: number;                 // 当前权重 (0.0 ~ 1.0)
  lastUsedAt: string | null;           // 最近一次被使用的时间
  cooldownUntil: string | null;        // 冷却期结束时间
  usageRoles: string[];                // 历史使用角色记录
  status: 'fresh' | 'active' | 'cooling' | 'archived';

  // —— 去重字段 ——
  titleHash: string | null;            // 归一化标题的 hash
  duplicateOf: string | null;          // 若是重复的，指向原条目 ID
}
```

### 5.3 层级访问控制

```typescript
/** 根据阶段返回不同层级的数据 */
class DataLayerAccessor {
  /** Stage 1: 只返回 Catalog 层（按 usageWeight 加权排序，过滤冷却中和已归档的条目） */
  getCatalog(items: SourceItem[]): CatalogEntry[] {
    return items
      .filter(i => i.status !== 'cooling' && i.status !== 'archived')
      .filter(i => !i.duplicateOf)  // 不展示重复条目
      .sort((a, b) => b.usageWeight - a.usageWeight)
      .map(item => ({
        id: item.id,
        title: item.title,
        source: item.source,
        category: item.category,
        previousRoles: item.usageRoles, // 供 Stage 1 参考角色历史
      }));
  }

  /** Content Reveal: 返回选中条目的 Abstract + Content + Image */
  revealContent(items: SourceItem[], selectedIds: string[], config: RevealConfig): RevealedContent[] {
    return items
      .filter(item => selectedIds.includes(item.id))
      .map(item => ({
        id: item.id,
        title: item.title,
        content: this.truncateToTokenLimit(
          item.content || item.abstract || '',
          config.maxTokensPerSource
        ),
        imageUrl: item.imageUrl,
      }));
  }
}
```

